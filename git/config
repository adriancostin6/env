# This is Git's per-user configuration file.
#
[core]
	pager = delta
[user]
	name = Adrian Costin
[include]
	path=catppuccin.gitconfig
[includeIf "gitdir:/localdev/adrianc/repos/work/"]
	path=.gitconfig-work
[includeIf "gitdir:/localdev/adrianc/repos/personal/"]
	path=.gitconfig-personal
[pull]
	rebase = true
[merge]
	ff = only
	conflictstyle = diff3
	tool = custom
[interactive]
	diffFilter = delta --color-only --features=interactive
[mergetool "custom"]
	cmd = "nvim -d -c \"4wincmd w\" -c \"wincmd J\" \"$LOCAL\" \"$BASE\" \"$REMOTE\" \"$MERGED\""
[credential "https://github.com"]
	helper = 
	helper = !/u/adrianc/.local/bin/apps/gh auth git-credential
[credential "https://gist.github.com"]
	helper = 
	helper = !/u/adrianc/.local/bin/apps/gh auth git-credential
